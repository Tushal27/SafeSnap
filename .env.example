# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=safesnap
POSTGRES_USER=safesnap
POSTGRES_PASSWORD=change_me_in_production

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_in_production

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Must be a cryptographically random string of at least 256 bits (32+ bytes)
# Generate with: openssl rand -base64 64
JWT_SECRET=change_me_in_production_use_openssl_rand_base64_64
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the dashboard
ALLOWED_ORIGINS=http://localhost:5173

# ─── Dashboard (Vite) ────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws/alerts
